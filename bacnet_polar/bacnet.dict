# =========================
# BACnet/IP dictionary for bacnet-stack apps/server/main.c
# direct source program + preeny(desock/desockmulti)
# =========================

# ---- BVLC / BACnet-IP ----
bvlc_type="\x81"

bvlc_result="\x00"
bvlc_write_bdt="\x01"
bvlc_read_bdt="\x02"
bvlc_read_bdt_ack="\x03"
bvlc_forwarded_npdu="\x04"
bvlc_register_fd="\x05"
bvlc_read_fdt="\x06"
bvlc_read_fdt_ack="\x07"
bvlc_delete_fdt="\x08"
bvlc_distribute_broadcast="\x09"
bvlc_original_unicast="\x0a"
bvlc_original_broadcast="\x0b"

bip_hdr_unicast="\x81\x0a"
bip_hdr_broadcast="\x81\x0b"
bip_hdr_forwarded="\x81\x04"

len_0004="\x00\x04"
len_0006="\x00\x06"
len_0008="\x00\x08"
len_000a="\x00\x0a"
len_000c="\x00\x0c"
len_0010="\x00\x10"
len_0011="\x00\x11"
len_0015="\x00\x15"
len_0018="\x00\x18"
len_0020="\x00\x20"
len_0040="\x00\x40"
len_0080="\x00\x80"
len_0100="\x01\x00"
len_0200="\x02\x00"

# ---- NPDU ----
npdu_ver_1="\x01"

npdu_ctl_apdu="\x00"
npdu_ctl_reply_expected="\x04"
npdu_ctl_src_spec="\x08"
npdu_ctl_dst_spec="\x20"
npdu_ctl_dst_reply="\x24"
npdu_ctl_dst_src="\x28"
npdu_ctl_netmsg="\x80"
npdu_ctl_netmsg_dst="\xa0"

dnet_broadcast="\xff\xff"
dlen_0="\x00"
hop_255="\xff"

netmsg_who_is_router="\x00"
netmsg_i_am_router="\x01"
netmsg_i_could_be_router="\x02"
netmsg_reject_message_to_network="\x03"
netmsg_router_busy="\x04"
netmsg_router_available="\x05"
netmsg_init_routing_table="\x06"
netmsg_init_routing_table_ack="\x07"

# ---- APDU type nibble / common fields ----
apdu_confirmed_req="\x00"
apdu_confirmed_req_sa="\x02"
apdu_confirmed_req_more="\x04"
apdu_confirmed_req_seg="\x08"

apdu_unconfirmed_req="\x10"
apdu_simple_ack="\x20"
apdu_complex_ack="\x30"
apdu_segment_ack="\x40"
apdu_error="\x50"
apdu_reject="\x60"
apdu_abort="\x70"

max_apdu_50="\x00"
max_apdu_128="\x01"
max_apdu_206="\x02"
max_apdu_480="\x03"
max_apdu_1024="\x04"
max_apdu_1476="\x05"

invoke_00="\x00"
invoke_01="\x01"
invoke_7f="\x7f"
invoke_ff="\xff"

# ---- Unconfirmed service choice ----
svc_ucov_notification="\x02"
svc_unconfirmed_private_transfer="\x04"
svc_time_synchronization="\x06"
svc_who_has="\x07"
svc_who_is="\x08"
svc_utc_time_synchronization="\x09"
svc_write_group="\x0a"

# ---- Confirmed service choice ----
svc_acknowledge_alarm="\x00"
svc_subscribe_cov="\x05"
svc_atomic_read_file="\x06"
svc_atomic_write_file="\x07"
svc_create_object="\x0a"
svc_delete_object="\x0b"
